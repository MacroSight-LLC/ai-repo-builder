# ============================================================
# AI Repo Builder — Environment Variables
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================
#
# CHOOSE YOUR LLM PROVIDER (uncomment ONE section below):
#
#   • IBM WatsonX   — enterprise, Llama-4 default
#   • OpenAI        — GPT-4o default (also works with any OpenAI-compatible API)
#   • Groq          — fast open-source models
#
# Whichever provider you configure will be used for *both*
# spec generation (Stage 1) and the build agent (Stage 2).
# ============================================================

# ── Option A: IBM WatsonX ─────────────────────────────────
# Get credentials at: https://cloud.ibm.com/watsonx
# WATSONX_API_KEY=
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_PROJECT_ID=

# ── Option B: OpenAI (or compatible) ─────────────────────
# OPENAI_API_KEY=sk-your-openai-api-key
# MODEL_NAME=gpt-4o
# AGENT_SETTING_CONFIG=settings.openai.toml
# For custom/self-hosted endpoints, also set:
# OPENAI_BASE_URL=https://your-endpoint/v1

# ── Option C: Groq ───────────────────────────────────────
# GROQ_API_KEY=gsk-your-groq-api-key
# MODEL_NAME=llama-3.3-70b-versatile
# AGENT_SETTING_CONFIG=settings.groq.toml

# Spec generation model override (optional — auto-detected from provider):
# SPEC_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct-fp8

# ── GitHub (optional — for repo creation) ─────────────────
# Fine-grained token: https://github.com/settings/personal-access-tokens/new
# Permissions needed: Contents (rw), Administration (rw), Metadata (ro)
GITHUB_TOKEN=
GITHUB_OWNER=

# ── Brave Search (optional — for web search) ──────────────
# Free tier: 2000 queries/month at https://brave.com/search/api/
BRAVE_API_KEY=

# ── IBM Cloud (optional — for deploy + CI/CD) ─────────────
# Shared API key for Code Engine + DevOps Toolchain
IBMCLOUD_API_KEY=
CODE_ENGINE_PROJECT=
CODE_ENGINE_REGION=us-south
IBMCLOUD_REGION=us-south

# ── IBM QRadar (optional — for security scanning) ─────────
# QRADAR_HOST=
# QRADAR_API_TOKEN=
# QRADAR_PORT=443

# ── IBM Instana (optional — for APM observability) ────────
# INSTANA_API_TOKEN=
# INSTANA_BASE_URL=https://your-tenant.instana.io

# ── Database (auto-configured by docker compose) ──────────
POSTGRES_URL=postgresql://cuga:cuga@localhost:5432/cuga_dev
REDIS_URL=redis://localhost:6379

# ── Optional: Langfuse tracing ────────────────────────────
# LANGFUSE_SECRET_KEY="sk-lf-xxx"
# LANGFUSE_PUBLIC_KEY="pk-lf-xxx"
# LANGFUSE_HOST="https://us.cloud.langfuse.com"
# DYNACONF_ADVANCED_FEATURES__LANGFUSE_TRACING=true
# Docker-compose Langfuse secrets (override defaults):
# NEXTAUTH_SECRET=generate-a-random-secret
# SALT=generate-a-random-salt

# ── Optional: OIDC auth ──────────────────────────────────
# OIDC_CLIENT_ID="your-client-id"
# OIDC_CLIENT_SECRET="your-client-secret"
# OIDC_DISCOVERY_URL="https://your-tenant/.well-known/openid-configuration"
# OIDC_REDIRECT_URI="https://localhost:7860/manage"
# DYNACONF_AUTH__ENABLED=true

# ── Optional: E2B sandbox ────────────────────────────────
# E2B_API_KEY="e2b_xxx"
